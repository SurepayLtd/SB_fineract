<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <!--
        TENANT 2FA CONFIGURATION CHANGESETS

        These changesets are OPTIONAL and meant for manual execution or specific deployment scenarios.
        They allow you to configure which tenants should have 2FA enabled.

        IMPORTANT: The global flag fineract.security.2fa.enabled must also be true for 2FA to be enforced.

        USAGE:
        - Uncomment the desired changeset(s) based on your requirements
        - Update the context attribute or use Liquibase contexts to control execution
        - Example: liquibase with contexts enable-2fa-production update
    -->

    <!--
        CHANGESET 1: Enable 2FA for production tenant
        Context: enable-2fa-production
    -->
    <changeSet author="johnboscomwesigye@gmail.com" id="enable-2fa-production" context="enable-2fa-production" runOnChange="false">
        <comment>Enable Two-Factor Authentication for production tenant</comment>
        <update tableName="tenants">
            <column name="two_factor_enabled" valueBoolean="true"/>
            <where>identifier = 'production'</where>
        </update>
        <rollback>
            <update tableName="tenants">
                <column name="two_factor_enabled" valueBoolean="false"/>
                <where>identifier = 'production'</where>
            </update>
        </rollback>
    </changeSet>

    <!--
        CHANGESET 2: Enable 2FA for multiple specific tenants
        Context: enable-2fa-multiple
    -->
    <changeSet author="fineract" id="enable-2fa-multiple-tenants" context="enable-2fa-multiple" runOnChange="false">
        <comment>Enable Two-Factor Authentication for multiple specific tenants</comment>
        <update tableName="tenants">
            <column name="two_factor_enabled" valueBoolean="true"/>
            <where>identifier IN ('tenant1', 'tenant2', 'tenant3')</where>
        </update>
        <rollback>
            <update tableName="tenants">
                <column name="two_factor_enabled" valueBoolean="false"/>
                <where>identifier IN ('tenant1', 'tenant2', 'tenant3')</where>
            </update>
        </rollback>
    </changeSet>

    <!--
        CHANGESET 3: Enable 2FA for all tenants
        Context: enable-2fa-all
        WARNING: This will enable 2FA for ALL tenants in the system
    -->
    <changeSet author="fineract" id="enable-2fa-all-tenants" context="enable-2fa-all" runOnChange="false">
        <comment>Enable Two-Factor Authentication for ALL tenants</comment>
        <update tableName="tenants">
            <column name="two_factor_enabled" valueBoolean="true"/>
        </update>
        <rollback>
            <update tableName="tenants">
                <column name="two_factor_enabled" valueBoolean="false"/>
            </update>
        </rollback>
    </changeSet>

    <!--
        CHANGESET 4: Disable 2FA for development tenant
        Context: disable-2fa-development
    -->
    <changeSet author="fineract" id="disable-2fa-development" context="disable-2fa-development" runOnChange="false">
        <comment>Disable Two-Factor Authentication for development tenant</comment>
        <update tableName="tenants">
            <column name="two_factor_enabled" valueBoolean="false"/>
            <where>identifier = 'development'</where>
        </update>
        <rollback>
            <update tableName="tenants">
                <column name="two_factor_enabled" valueBoolean="true"/>
                <where>identifier = 'development'</where>
            </update>
        </rollback>
    </changeSet>

    <!--
        CHANGESET 5: Enable 2FA for production-like tenants (pattern matching)
        Context: enable-2fa-production-pattern
    -->
    <changeSet author="fineract" id="enable-2fa-production-pattern" context="enable-2fa-production-pattern" runOnChange="false">
        <comment>Enable Two-Factor Authentication for production-like tenants (identifier contains 'prod' or 'production')</comment>
        <sql>
            UPDATE tenants
            SET two_factor_enabled = true
            WHERE identifier LIKE '%prod%' OR identifier LIKE '%production%';
        </sql>
        <rollback>
            <sql>
                UPDATE tenants
                SET two_factor_enabled = false
                WHERE identifier LIKE '%prod%' OR identifier LIKE '%production%';
            </sql>
        </rollback>
    </changeSet>

    <!--
        CHANGESET 6: Enable 2FA for recently created tenants
        Context: enable-2fa-recent-tenants
    -->
    <changeSet author="fineract" id="enable-2fa-recent-tenants" context="enable-2fa-recent-tenants" runOnChange="false">
        <comment>Enable Two-Factor Authentication for tenants created after 2024-01-01</comment>
        <sql>
            UPDATE tenants
            SET two_factor_enabled = true
            WHERE created_date >= '2024-01-01';
        </sql>
        <rollback>
            <sql>
                UPDATE tenants
                SET two_factor_enabled = false
                WHERE created_date >= '2024-01-01';
            </sql>
        </rollback>
    </changeSet>

    <!--
        CHANGESET 7: Enable 2FA for specific tenant by name
        Context: enable-2fa-by-name
    -->
    <changeSet author="fineract" id="enable-2fa-main-tenant" context="enable-2fa-by-name" runOnChange="false">
        <comment>Enable Two-Factor Authentication for main/default tenant</comment>
        <update tableName="tenants">
            <column name="two_factor_enabled" valueBoolean="true"/>
            <where>identifier = 'default' OR identifier = 'main'</where>
        </update>
        <rollback>
            <update tableName="tenants">
                <column name="two_factor_enabled" valueBoolean="false"/>
                <where>identifier = 'default' OR identifier = 'main'</where>
            </update>
        </rollback>
    </changeSet>

    <!--
        CHANGESET 8: Disable 2FA for test and staging tenants
        Context: disable-2fa-test-staging
    -->
    <changeSet author="fineract" id="disable-2fa-test-staging" context="disable-2fa-test-staging" runOnChange="false">
        <comment>Disable Two-Factor Authentication for test and staging environments</comment>
        <update tableName="tenants">
            <column name="two_factor_enabled" valueBoolean="false"/>
            <where>identifier IN ('dev', 'test', 'staging', 'development')</where>
        </update>
        <rollback>
            <update tableName="tenants">
                <column name="two_factor_enabled" valueBoolean="true"/>
                <where>identifier IN ('dev', 'test', 'staging', 'development')</where>
            </update>
        </rollback>
    </changeSet>

    <!--
        CHANGESET 9: Enable 2FA for UAT tenant
        Context: enable-2fa-uat
    -->
    <changeSet author="fineract" id="enable-2fa-uat" context="enable-2fa-uat" runOnChange="false">
        <comment>Enable Two-Factor Authentication for UAT tenant</comment>
        <update tableName="tenants">
            <column name="two_factor_enabled" valueBoolean="true"/>
            <where>identifier = 'uat' OR identifier = 'user-acceptance'</where>
        </update>
        <rollback>
            <update tableName="tenants">
                <column name="two_factor_enabled" valueBoolean="false"/>
                <where>identifier = 'uat' OR identifier = 'user-acceptance'</where>
            </update>
        </rollback>
    </changeSet>

    <!--
        CHANGESET 10: Gradual rollout - Pilot tenant
        Context: enable-2fa-pilot
    -->
    <changeSet author="fineract" id="enable-2fa-pilot-tenant" context="enable-2fa-pilot" runOnChange="false">
        <comment>Enable Two-Factor Authentication for pilot tenant (gradual rollout - phase 1)</comment>
        <update tableName="tenants">
            <column name="two_factor_enabled" valueBoolean="true"/>
            <where>identifier = 'pilot'</where>
        </update>
        <rollback>
            <update tableName="tenants">
                <column name="two_factor_enabled" valueBoolean="false"/>
                <where>identifier = 'pilot'</where>
            </update>
        </rollback>
    </changeSet>

</databaseChangeLog>
