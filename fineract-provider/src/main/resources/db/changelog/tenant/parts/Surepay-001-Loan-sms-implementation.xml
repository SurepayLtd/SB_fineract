<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">
    <changeSet author="fineract" id="loan-sms-implementation">
        <insert tableName="c_configuration">
            <column name="name" value="enable-sms-notifications"/>
            <column name="value"/>
            <column name="date_value"/>
            <column name="string_value"/>
            <column name="enabled" valueBoolean="false"/>
            <column name="is_trap_door" valueBoolean="false"/>
            <column name="description"/>
        </insert>
    </changeSet>
    <changeSet author="fineract" id="add_momo_payment_type">
        <insert tableName="m_payment_type">
            <column name="id" value="100"/>
            <column name="value" value="SurePay Mobile Money Payment"/>
            <column name="description" value="SurePay Mobile Money Payment"/>
            <column name="is_cash_payment" valueBoolean="false"/>
            <column name="order_position" valueNumeric="0"/>
            <column name="code_name" value="SURE_PAY_MOMO_PAYMENT"/>
            <column name="is_system_defined" valueBoolean="true"/>
        </insert>
    </changeSet>
    <changeSet author="fineract" id="SurePay-Momo-Integration">
        <insert tableName="c_configuration">
            <column name="name" value="enable-surepay-mobile-money-payment"/>
            <column name="value"/>
            <column name="date_value"/>
            <column name="string_value"/>
            <column name="enabled" valueBoolean="false"/>
            <column name="is_trap_door" valueBoolean="false"/>
            <column name="description" value="Enable Mobile Money Integrations with Surepay Payments"/>
        </insert>
    </changeSet>
    <changeSet author="fineract" id="add_momo_pay_is_disbursed_via_momo_pay_on_a_loan_account">
        <addColumn tableName="m_loan">
            <column name="is_disbursed_via_momo_pay"  type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet author="fineract" id="add_momo_pay_disbursement_payout_completed_on_a_loan_account">
        <addColumn tableName="m_loan">
            <column name="disbursement_payout_completed"  type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet author="fineract" id="create_m_momo_loan_payment_transaction_table">
        <createTable tableName="m_momo_loan_payment_transaction">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="loan_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="loan_transaction_id" type="BIGINT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="middleware_reference_no" type="BIGINT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="transaction_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(19, 6)">
                <constraints nullable="false"/>
            </column>
            <column name="transaction_charge" type="DECIMAL(19, 6)">
                <constraints nullable="false"/>
            </column>
            <column name="is_reversed" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="status_code" type="VARCHAR(10)">
            </column>
            <column name="status_desc" type="VARCHAR(255)">
            </column>
            <column name="request_body" type="TEXT">
            </column>
            <column name="response_body" type="TEXT">
            </column>
            <column name="error_msg" type="TEXT">
            </column>

            <column name="created_by" type="BIGINT">
                <constraints nullable="true"
                             foreignKeyName="FK_m_mobile_money_transaction_request_createdby"
                             references="m_appuser(id)"/>
            </column>
            <column name="created_on_utc" type="DATETIME">
                <constraints nullable="false" />
            </column>
            <column name="last_modified_by" type="BIGINT">
                <constraints nullable="true"
                             foreignKeyName="FK_m_mobile_money_transaction_request_modified_by"
                             references="m_appuser(id)"/>
            </column>
            <column name="last_modified_on_utc" type="DATETIME">
                <constraints nullable="false" />
            </column>

        </createTable>
    </changeSet>

    <changeSet id="Surepay-002-change-middleware-reference-no-to-varchar" author="bosco">
        <modifyDataType
                tableName="m_momo_loan_payment_transaction"
                columnName="middleware_reference_no"
                newDataType="VARCHAR(255)"/>
    </changeSet>

    <changeSet id="Add_Job_To_Process_Loan_Transactions_On_Momo_Payment" author="bosco">
    <insert tableName="job">
        <column name="name" value="Process Loan Transactions On Momo Payment"/>
        <column name="display_name" value="Process Loan Transactions On Momo Payment"/>
        <column name="cron_expression" value="0 0 0 1/1 * ? *"/>
        <column name="create_time" valueDate="${current_datetime}"/>
        <column name="task_priority" valueNumeric="5"/>
        <column name="group_name"/>
        <column name="previous_run_start_time"/>
        <column name="job_key" value="Process Loan Transactions On Momo PaymentJobDetail1 _ DEFAULT"/>
        <column name="initializing_errorlog"/>
        <column name="is_active" valueBoolean="true"/>
        <column name="currently_running" valueBoolean="false"/>
        <column name="updates_allowed" valueBoolean="true"/>
        <column name="scheduler_group" valueNumeric="0"/>
        <column name="is_misfired" valueBoolean="false"/>
        <column name="node_id" valueNumeric="1"/>
        <column name="is_mismatched_job" valueBoolean="true"/>
        <column name="short_name" value="MOMO_PAY"/>
    </insert>
    </changeSet>
    <changeSet author="fineract" id="add_venderTranId_to_m_momo_loan_payment_transaction">
        <addColumn tableName="m_momo_loan_payment_transaction">
            <column name="vendor_tran_id"  type="VARCHAR(255)">
                <constraints nullable="false" />
            </column>
        </addColumn>
    </changeSet>
    <changeSet author="fineract" id="add_add_disbursement_payout_completed_date_to_m_loan_to_m_loan">
        <addColumn tableName="m_loan">
            <column name="disbursement_payout_completed_date"  type="DATETIME">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet author="fineract" id="add_check_transaction_status_response_to_m_momo_loan_payment_transaction">
        <addColumn tableName="m_momo_loan_payment_transaction">
            <column name="check_transaction_status_response"  type="TEXT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet author="fineract" id="add_unique_constraint_vendor_tran_id_to_m_momo_loan_payment_transaction">
        <addUniqueConstraint
                columnNames="vendor_tran_id"
                constraintName="uk_m_momo_loan_payment_transaction_vendor_tran_id"
                tableName="m_momo_loan_payment_transaction"/>
    </changeSet>
    <changeSet author="fineract" id="add_unique_constraint_loan_transaction_id_to_m_momo_loan_payment_transaction">
        <addUniqueConstraint
                columnNames="loan_transaction_id"
                constraintName="uk_m_momo_loan_payment_transaction_loan_transaction_id"
                tableName="m_momo_loan_payment_transaction"/>
    </changeSet>
    <changeSet author="fineract" id="middleware_reference_no_to_m_loan">
        <addColumn tableName="m_loan">
            <column name="middleware_reference_no"  type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet author="fineract" id="create_m_momo_credential_details">
        <createTable tableName="m_momo_credential_details">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="momo_vendor_code" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="momo_secret" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="momo_password" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

        </createTable>
    </changeSet>

</databaseChangeLog>
